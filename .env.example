# OpenAI API Key - get yours at https://platform.openai.com/api-keys
# Leave empty or omit to use mock mode (no API calls, works offline)
OPENAI_API_KEY=

# Set to "true" to force mock mode regardless of API key presence
USE_MOCK_LLM=false

# Base URL used by Playwright tests as default navigation target
BASE_URL=https://playwright.dev

# OpenAI model to use (gpt-4o is recommended for better test quality)
OPENAI_MODEL=gpt-4o-mini
